---
import site from "../data/site.json";
import LinkButton from "../components/LinkButton.astro";
import "../styles/global.css";

const title = `${site.name}`;
const description = site.tagline;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,600;0,700;1,500&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://link.${site.domain}`} />
    <meta property="og:image" content={`https://link.${site.domain}/og.svg`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <div class="container">
      <header>
        <img src="/logo.png" alt="D'Luca" class="header-logo" />
        {site.tagline && <p class="tagline">{site.tagline}</p>}
      </header>

      <nav class="link-list">
        {
          site.links.map((link) => (
            link.icon === "menu" ? (
              <a href="#" class="link-btn" id="menu-btn">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
                <span class="btn-label">View menu</span>
                <span class="arrow">&rarr;</span>
              </a>
            ) : link.icon === "star" ? (
              <a href="#" class="link-btn" id="events-btn">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <span class="btn-label">Book an event</span>
                <span class="arrow">&rarr;</span>
              </a>
            ) : link.icon === "calendar" ? (
              <a href="#" class="link-btn" id="reserve-btn">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span class="btn-label">Reserve a table</span>
                <span class="arrow">&rarr;</span>
              </a>
            ) : (
              <LinkButton
                label={link.label}
                href={link.href}
                icon={link.icon}
                placeholder={link.placeholder}
              />
            )
          ))
        }
      </nav>

      {site.socials && site.socials.length > 0 && (
        <div class="socials">
          {site.socials.map((s) => (
            <a
              href={s.href}
              class="social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
            >
              {s.icon === "instagram" && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              )}
              {s.icon === "facebook" && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
              )}
              {s.icon === "tiktok" && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>
                </svg>
              )}
              {s.icon === "google" && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      )}

      <footer>
        &copy; {new Date().getFullYear()} {site.name}
      </footer>
    </div>

    <!-- Menu Image Modal -->
    <div id="menu-modal" class="modal-overlay">
      <div class="modal-backdrop" id="modal-backdrop"></div>
      <div class="modal-content">
        <div class="modal-header">
          <span class="modal-title">Menu</span>
          <button id="modal-close" class="modal-close" aria-label="Close menu">&times;</button>
        </div>
        <div class="modal-body" id="modal-body">
          <img src="/menu-pages/page-1.jpg" alt="Menu page 1" class="menu-page-img" loading="eager" />
          <img src="/menu-pages/page-2.jpg" alt="Menu page 2" class="menu-page-img" loading="lazy" />
          <img src="/menu-pages/page-3.jpg" alt="Menu page 3" class="menu-page-img" loading="lazy" />
          <img src="/menu-pages/page-4.jpg" alt="Menu page 4" class="menu-page-img" loading="lazy" />
          <img src="/menu-pages/page-5.jpg" alt="Menu page 5" class="menu-page-img" loading="lazy" />
          <img src="/menu-pages/page-6.jpg" alt="Menu page 6" class="menu-page-img" loading="lazy" />
          <img src="/menu-pages/page-7.jpg" alt="Menu page 7" class="menu-page-img" loading="lazy" />
          <img src="/menu-pages/page-8.jpg" alt="Menu page 8" class="menu-page-img" loading="lazy" />
          <img src="/menu-pages/page-9.jpg" alt="Menu page 9" class="menu-page-img" loading="lazy" />
          <img src="/menu-pages/page-10.jpg" alt="Menu page 10" class="menu-page-img" loading="lazy" />
          <img src="/menu-pages/page-11.jpg" alt="Menu page 11" class="menu-page-img" loading="lazy" />
        </div>
      </div>
    </div>

    <!-- Events Modal -->
    <div id="events-modal" class="modal-overlay">
      <div class="modal-backdrop" id="events-backdrop"></div>
      <div class="modal-content modal-content--narrow">
        <div class="modal-header">
          <span class="modal-title">Book an event</span>
          <button id="events-close" class="modal-close" aria-label="Close">&times;</button>
        </div>
        <div class="events-body">
          <a href="#" class="events-choice" id="coffee-cart-choice">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
            <span>Coffee Cart</span>
            <span class="arrow">&rarr;</span>
          </a>
          <a href="#" class="events-choice" id="private-event-choice">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Private Event</span>
            <span class="arrow">&rarr;</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Coffee Cart Modal -->
    <div id="coffee-cart-modal" class="modal-overlay">
      <div class="modal-backdrop" id="coffee-backdrop"></div>
      <div class="modal-content modal-content--full">
        <div class="modal-header">
          <span class="modal-title">Coffee Cart</span>
          <button id="coffee-close" class="modal-close" aria-label="Close">&times;</button>
        </div>
        <div class="modal-preview">
          <div class="modal-preview-img-wrap">
            <img src="/coffee-cart.jpg" alt="Coffee Cart Package" class="preview-img" loading="eager" />
          </div>
          <div class="modal-cta">
            <a href="https://m.me/907371789137065" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--outline">Message us on Facebook</a>
            <a href="https://docs.google.com/forms/d/1Byitxr2sTRUNinBZ_ffe4egPYFJEiIJ2O7ogfaBphi4/viewform?edit_requested=true" target="_blank" rel="noopener noreferrer" class="cta-btn" id="coffee-inquire">Fill out booking form</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Private Event Modal -->
    <div id="private-event-modal" class="modal-overlay">
      <div class="modal-backdrop" id="private-backdrop"></div>
      <div class="modal-content modal-content--full">
        <div class="modal-header">
          <span class="modal-title">Private Event</span>
          <button id="private-close" class="modal-close" aria-label="Close">&times;</button>
        </div>
        <div class="modal-preview">
          <div class="modal-preview-img-wrap">
            <img src="/private-event.jpg" alt="Private Event Package" class="preview-img" loading="eager" />
          </div>
          <div class="modal-cta">
            <a href="https://m.me/907371789137065" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--outline">Message us on Facebook</a>
            <a href="#" class="cta-btn" id="private-inquire">Fill out booking form</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Reservation Modal -->
    <div id="reserve-modal" class="modal-overlay">
      <div class="modal-backdrop" id="reserve-backdrop"></div>
      <div class="modal-content modal-content--narrow">
        <div class="modal-header">
          <span class="modal-title">Reserve a table</span>
          <button id="reserve-close" class="modal-close" aria-label="Close">&times;</button>
        </div>
        <form class="reserve-form" id="reserve-form">
          <label class="reserve-field">
            <span>Name <em>*</em></span>
            <input type="text" name="name" placeholder="Your name" required />
          </label>
          <label class="reserve-field">
            <span>Contact <em>*</em></span>
            <input type="tel" name="contact" placeholder="09XX XXX XXXX" required />
          </label>
          <label class="reserve-field">
            <span>Date <em>*</em></span>
            <div class="custom-date-wrap">
              <select name="month" class="custom-select" id="rs-month" required></select>
              <select name="day" class="custom-select" id="rs-day" required></select>
              <select name="year" class="custom-select" id="rs-year" required></select>
              <input type="hidden" name="date" id="rs-date" />
            </div>
          </label>
          <label class="reserve-field">
            <span>Time <em>*</em></span>
            <select name="time" class="custom-select" id="rs-time" required>
              <option value="">Select time</option>
            </select>
          </label>
          <label class="reserve-field">
            <span>Guests <em>*</em></span>
            <input type="number" name="guests" min="1" placeholder="2" required />
          </label>
          <label class="reserve-field">
            <span>Notes</span>
            <input type="text" name="notes" placeholder="Allergies, occasion..." />
          </label>
          <button type="submit" class="reserve-submit">Send reservation</button>
        </form>
      </div>
    </div>

    <script>
      const menuBtn = document.getElementById("menu-btn");
      const modal = document.getElementById("menu-modal");
      const closeBtn = document.getElementById("modal-close");
      const backdrop = document.getElementById("modal-backdrop");

      function openModal(el) {
        el.classList.add("visible");
        document.body.style.overflow = "hidden";
        document.body.style.touchAction = "none";
      }

      function closeModal(el) {
        el.classList.remove("visible");
        document.body.style.overflow = "";
        document.body.style.touchAction = "";
      }

      if (menuBtn) {
        menuBtn.addEventListener("click", (e) => {
          e.preventDefault();
          openModal(modal);
        });
      }

      if (closeBtn) {
        closeBtn.addEventListener("click", () => closeModal(modal));
      }

      if (backdrop) {
        backdrop.addEventListener("click", () => closeModal(modal));
      }

      /* Events */
      const eventsBtn = document.getElementById("events-btn");
      const eventsModal = document.getElementById("events-modal");
      const eventsClose = document.getElementById("events-close");
      const eventsBackdrop = document.getElementById("events-backdrop");

      const coffeeChoice = document.getElementById("coffee-cart-choice");
      const privateChoice = document.getElementById("private-event-choice");
      const coffeeModal = document.getElementById("coffee-cart-modal");
      const privateModal = document.getElementById("private-event-modal");

      if (eventsBtn) {
        eventsBtn.addEventListener("click", (e) => {
          e.preventDefault();
          openModal(eventsModal);
        });
      }

      if (eventsClose) {
        eventsClose.addEventListener("click", () => closeModal(eventsModal));
      }

      if (eventsBackdrop) {
        eventsBackdrop.addEventListener("click", () => closeModal(eventsModal));
      }

      if (coffeeChoice) {
        coffeeChoice.addEventListener("click", (e) => {
          e.preventDefault();
          closeModal(eventsModal);
          openModal(coffeeModal);
        });
      }

      if (privateChoice) {
        privateChoice.addEventListener("click", (e) => {
          e.preventDefault();
          closeModal(eventsModal);
          openModal(privateModal);
        });
      }

      function setupModalClose(modalId, closeId, backdropId) {
        const m = document.getElementById(modalId);
        const c = document.getElementById(closeId);
        const b = document.getElementById(backdropId);
        if (c) c.addEventListener("click", () => closeModal(m));
        if (b) b.addEventListener("click", () => closeModal(m));
      }

      setupModalClose("coffee-cart-modal", "coffee-close", "coffee-backdrop");
      setupModalClose("private-event-modal", "private-close", "private-backdrop");

      /* Reserve */
      const reserveBtn = document.getElementById("reserve-btn");
      const reserveModal = document.getElementById("reserve-modal");
      const reserveClose = document.getElementById("reserve-close");
      const reserveBackdrop = document.getElementById("reserve-backdrop");
      const reserveForm = document.getElementById("reserve-form");
      const rsMonth = document.getElementById("rs-month");
      const rsDay = document.getElementById("rs-day");
      const rsYear = document.getElementById("rs-year");
      const rsDate = document.getElementById("rs-date");
      const rsTime = document.getElementById("rs-time");

      // Populate day select
      const today = new Date();
      const currentYear = today.getFullYear();
      const currentMonthNum = today.getMonth(); // 0-indexed
      const currentDay = today.getDate();

      const monthNames = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];

      function populateMonths(year) {
        rsMonth.innerHTML = '';
        const start = (year === currentYear) ? currentMonthNum : 0;
        for (let m = start; m < 12; m++) {
          const val = String(m + 1).padStart(2, "0");
          const opt = document.createElement("option");
          opt.value = val;
          opt.textContent = monthNames[m];
          rsMonth.appendChild(opt);
        }
      }

      function populateDays(month, year) {
        rsDay.innerHTML = '';
        const daysInMonth = new Date(year, month, 0).getDate();
        const isCurrentMonth = year === currentYear && month === String(currentMonthNum + 1).padStart(2, "0");
        const startDay = isCurrentMonth ? currentDay : 1;
        for (let d = startDay; d <= daysInMonth; d++) {
          const opt = document.createElement("option");
          opt.value = String(d).padStart(2, "0");
          opt.textContent = d;
          rsDay.appendChild(opt);
        }
      }

      // Populate year select (current year only + next)
      for (let i = currentYear; i <= currentYear + 1; i++) {
        const opt = document.createElement("option");
        opt.value = i;
        opt.textContent = i;
        rsYear.appendChild(opt);
      }

      // Pre-fill today
      rsYear.value = currentYear;
      populateMonths(currentYear);
      rsMonth.value = String(currentMonthNum + 1).padStart(2, "0");
      populateDays(String(currentMonthNum + 1).padStart(2, "0"), currentYear);
      rsDay.value = String(currentDay).padStart(2, "0");
      // Set hidden date for today's pre-fill
      rsDate.value = `${rsYear.value}-${rsMonth.value}-${rsDay.value}`;

      // Populate time slots
      function populateTime(startHour) {
        rsTime.innerHTML = '<option value="">Select time</option>';
        const now = new Date();
        const currentHour = now.getHours();
        const currentMin = now.getMinutes();
        const isToday = rsYear.value == currentYear && rsMonth.value == String(currentMonthNum + 1).padStart(2, "0") && rsDay.value == String(currentDay).padStart(2, "0");
        for (let h = startHour; h <= 22; h++) {
          for (let m = 0; m < 60; m += 30) {
            if (isToday && (h < currentHour || (h === currentHour && m <= currentMin))) continue;
            const val = `${String(h).padStart(2, "0")}:${String(m).padStart(2, "0")}`;
            const label = h > 12 ? `${h - 12}:${String(m).padStart(2, "0")} PM` : h === 12 ? `12:${String(m).padStart(2, "0")} PM` : `${h}:${String(m).padStart(2, "0")} AM`;
            const opt = document.createElement("option");
            opt.value = val;
            opt.textContent = label;
            rsTime.appendChild(opt);
          }
        }
      }
      populateTime(11); // default
      function updateDate() {
        if (rsMonth.value && rsDay.value && rsYear.value) {
          rsDate.value = `${rsYear.value}-${rsMonth.value}-${rsDay.value}`;
          const d = new Date(parseInt(rsYear.value), parseInt(rsMonth.value) - 1, parseInt(rsDay.value));
          const day = d.getDay(); // 0=Sun, 1=Mon ... 6=Sat
          if (day >= 1 && day <= 4) { // Mon-Thu
            populateTime(12);
          } else { // Fri-Sun
            populateTime(11);
          }
        }
      }

      function onYearChange() {
        const prevMonth = rsMonth.value;
        populateMonths(parseInt(rsYear.value));
        // Re-select previous month if valid in new year
        const monthOpts = Array.from(rsMonth.options).map(o => o.value);
        if (monthOpts.includes(prevMonth)) {
          rsMonth.value = prevMonth;
        } else {
          rsMonth.value = "";
          rsDay.innerHTML = '';
          rsDay.value = "";
          rsDate.value = "";
          return;
        }
        if (rsMonth.value) {
          populateDays(rsMonth.value, parseInt(rsYear.value));
        }
        updateDate();
      }

      function onMonthChange() {
        if (rsMonth.value && rsYear.value) {
          populateDays(rsMonth.value, parseInt(rsYear.value));
        }
        updateDate();
      }

      rsMonth.addEventListener("change", onMonthChange);
      rsDay.addEventListener("change", updateDate);
      rsYear.addEventListener("change", onYearChange);

      if (reserveBtn) {
        reserveBtn.addEventListener("click", (e) => {
          e.preventDefault();
          openModal(reserveModal);
        });
      }

      if (reserveClose) {
        reserveClose.addEventListener("click", () => closeModal(reserveModal));
      }

      if (reserveBackdrop) {
        reserveBackdrop.addEventListener("click", () => closeModal(reserveModal));
      }

      if (reserveForm) {
        function timeTo12hr(val) {
          if (!val) return "";
          const [h, m] = val.split(":").map(Number);
          const ampm = h >= 12 ? "PM" : "AM";
          const h12 = h % 12 || 12;
          return `${h12}:${String(m).padStart(2, "0")} ${ampm}`;
        }
        reserveForm.addEventListener("submit", (e) => {
          e.preventDefault();
          const data = new FormData(reserveForm);
          const name = data.get("name");
          const contact = data.get("contact");
          const date = data.get("date");
          const time = data.get("time");
          const guests = data.get("guests");
          const notes = data.get("notes");
          function formatDate(ymd) {
            if (!ymd) return "";
            const [y, m, d] = ymd.split("-");
            const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
            return `${months[parseInt(m)-1]} ${parseInt(d)}, ${y}`;
          }
          let msg = `Hi D'Luca!\nI'd like to reserve a table for ${guests}\nDate: ${formatDate(date)}\nTime: ${timeTo12hr(time)}\nName: ${name}\nContact: ${contact}`;
          if (notes) msg += `\nNotes: ${notes}`;
          closeModal(reserveModal);
          reserveForm.reset();
          navigator.clipboard.writeText(msg).catch(function(){});
          var toast = document.createElement("div");
          toast.textContent = "✓ Message copied! Opening Messenger...";
          toast.style.cssText = "position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1a1a1a;color:#fff;padding:12px 20px;border-radius:10px;font-size:0.9rem;z-index:9999;font-family:sans-serif;box-shadow:0 4px 20px rgba(0,0,0,0.3);transition:opacity 0.3s";
          document.body.appendChild(toast);
          setTimeout(function(){ toast.style.opacity = "0"; setTimeout(function(){ toast.remove(); }, 300); }, 2500);
          setTimeout(function(){ window.location.href = "https://m.me/907371789137065"; }, 500);
        });
      }

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          closeModal(modal);
          closeModal(eventsModal);
          closeModal(coffeeModal);
          closeModal(privateModal);
          closeModal(reserveModal);
        }
      });

      // Auto-open modal from URL path or params
      const path = window.location.pathname.replace(/\/$/, "");
      const params = new URLSearchParams(window.location.search);
      const auto = params.get("auto") || path.replace("/", "");
      if (auto === "menu") openModal(modal);
      else if (auto === "events") { setTimeout(() => openModal(eventsModal), 100); }
      else if (auto === "reserve") openModal(reserveModal);
      else if (auto === "coffee") { setTimeout(() => { closeModal(eventsModal); openModal(coffeeModal); }, 150); }
